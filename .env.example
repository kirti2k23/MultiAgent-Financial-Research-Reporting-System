# Environment variables template — API keys go here
# ─────────────────────────────────────────────────────────────────────────────
# .env.example
# Autonomous Financial Research Agent — Environment Variables
#
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your actual API keys in .env
#   3. Never commit .env to GitHub (it's in .gitignore)
#
# REQUIRED vs OPTIONAL:
#   REQUIRED  → pipeline will NOT start without these
#   OPTIONAL  → pipeline runs, but that feature is disabled
# ─────────────────────────────────────────────────────────────────────────────


# ── LLM — OpenAI (REQUIRED) ───────────────────────────────────────────────────
# Used by all agents to call GPT-4o for analysis and report generation
# Get it at: https://platform.openai.com/api-keys
# Free tier: No. Requires billing. ~$0.01–0.05 per full pipeline run.
# OPENAI_API_KEY= OPENAI_API_KEY

# ── News Search — Tavily (REQUIRED) ───────────────────────────────────────────
# Used by news_search.py to fetch live financial news articles
# Get it at: https://app.tavily.com
# Free tier: Yes — 1,000 free searches/month. No credit card needed.
TAVILY_API_KEY=TAVILY_API_KEY


# ── Email Delivery — SendGrid (OPTIONAL) ──────────────────────────────────────
# Used by email_sender.py to email the final report
# Get it at: https://signup.sendgrid.com
# Free tier: Yes — 100 emails/day free forever
# If not set: report is saved locally but not emailed
# SENDGRID_API_KEY=SENDGRID_API_KEY
# SENDGRID_FROM_EMAIL=SENDGRID_FROM_EMAIL
# REPORT_RECIPIENT_EMAIL=REPORT_RECIPIENT_EMAIL


# ── Observability — LangSmith (OPTIONAL) ──────────────────────────────────────
# Traces every agent run — see exactly what each agent did, tokens used, timing
# Get it at: https://smith.langchain.com
# Free tier: Yes — free for personal/dev use
# If not set: pipeline runs fine, just no visual tracing dashboard
LANGCHAIN_API_KEY= LANGCHAIN_API_KEY
LANGCHAIN_TRACING_V2=LANGCHAIN_TRACING_V2
LANGCHAIN_PROJECT=LANGCHAIN_PROJECT


# ── Vector Store — ChromaDB (NO KEY NEEDED) ───────────────────────────────────
# ChromaDB runs locally on your machine — no API key required
# This just sets where ChromaDB saves its data on disk
CHROMA_PERSIST_DIR=CHROMA_PERSIST_DIR

NVIDIA_API_KEY= NVIDIA_API_KEY


# ── App Settings ──────────────────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR
# Use DEBUG during development to see every step
# Use INFO in production for clean output
LOG_LEVEL=INFO